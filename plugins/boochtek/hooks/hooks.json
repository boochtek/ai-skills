{
    "description": "Enforce Bash tool usage rules",
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/bash-guard.sh",
                        "timeout": 5
                    }
                ]
            }
        ]
    }
}
